{
  "name": "@nerdsnipe-inc/lofty-mcp",
  "version": "1.0.0",
  "description": "A Model Context Protocol (MCP) server for Lofty (formerly Chime) CRM — 120+ tools covering the full Lofty API",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lofty",
    "chime",
    "crm",
    "real-estate",
    "claude",
    "cursor",
    "ai"
  ],
  "homepage": "https://github.com/Nerdsnipe-Inc/lofty-mcp#readme",
  "bugs": {
    "url": "https://github.com/Nerdsnipe-Inc/lofty-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NerdSnipe-Inc/lofty-mcp.git"
  },
  "license": "Elastic-2.0",
  "author": "NerdSnipe Inc <hello@nerdsnipe.cc>",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "lofty-mcp": "./bin/lofty-mcp.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
